    "@univerjs/preset-sheets-core": "0.21.1",
    "element-plus": "^2.9.0",
    "vue": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
